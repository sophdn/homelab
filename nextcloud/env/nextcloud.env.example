# Copy to nextcloud.env, fill real values, chmod 600. Do NOT commit nextcloud.env.
# Passwords are alphanumeric (openssl rand -hex) by convention to avoid the
# compose $$-escaping trap entirely — no '$' in any value here.

# --- MariaDB ---
MYSQL_ROOT_PASSWORD=replace-with-openssl-rand-hex-24
MYSQL_PASSWORD=replace-with-openssl-rand-hex-24

# --- Redis (same value in both vars: server reads REDIS_PASSWORD, nextcloud reads REDIS_HOST_PASSWORD) ---
REDIS_PASSWORD=replace-with-openssl-rand-hex-24
REDIS_HOST_PASSWORD=replace-with-openssl-rand-hex-24

# --- Reverse-proxy identity (fill the real tailnet FQDN after `tailscale up`) ---
NEXTCLOUD_TRUSTED_DOMAINS=mini-pc.<tailnet>.ts.net localhost 127.0.0.1
OVERWRITEHOST=mini-pc.<tailnet>.ts.net
OVERWRITECLIURL=https://mini-pc.<tailnet>.ts.net
