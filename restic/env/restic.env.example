# Restic encryption passphrase + repository location.
#
# CRITICAL: the passphrase is the ONLY decryption key for the encrypted backup
# repo. Restic generates strong random passphrases — DO NOT use a memorable
# string. Generate with:
#
#   head -c 33 /dev/urandom | base64 | tr -d '=' | tr '+/' '-_'
#
# Once generated, this passphrase MUST be backed up OFF this disk:
# - A password manager entry, OR
# - A printed paper copy in a physical safe location, OR
# - An encrypted file on a different machine.
#
# If both ~/homelab/restic/env/restic.env AND the off-disk backup are lost,
# the encrypted repo is unrecoverable. Treat this as load-bearing.

RESTIC_PASSWORD=<placeholder-44-char-random>
RESTIC_REPOSITORY=/mnt/jellyfin/backups/homelab-restic
