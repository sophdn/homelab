# homelab health-poll config.
#
#   mkdir -p ~/.config/homelab-monitor
#   cp monitoring/monitor.env.example ~/.config/homelab-monitor/monitor.env
#   $EDITOR ~/.config/homelab-monitor/monitor.env
#
# The real file lives in ~/.config, NOT in this repo: a monitoring target and a
# ledger URL are deployment config, not source. Keeping them out means this repo
# carries no infra identifiers and the public mirror has nothing to scrub.

# REQUIRED. The host to watch, as an ssh destination. Key auth, BatchMode.
HOMELAB_MONITOR_TARGET=youruser@your-server

# REQUIRED. Base URL of the work-ledger HTTP surface that findings are filed
# into. This MUST NOT be a service on the monitored host: the whole point is
# that the alarm survives the host being down. It must be reachable from the
# observer.
HOMELAB_MONITOR_TOOLKIT_URL=http://localhost:3001

# Project the bugs are filed under.
#HOMELAB_MONITOR_PROJECT=homelab

# Goes into every bug slug (auto-<tag>-...). Short, stable, human. Changing it
# later orphans the dedupe: existing findings re-file under the new name.
#HOMELAB_MONITOR_HOST_TAG=homelab

# Report what would be filed, touch nothing.
#HOMELAB_MONITOR_DRY_RUN=1

# Passed through to health-report.sh on the target.
#HOMELAB_DISK_PCT_WARN=85
#HOMELAB_WATCH_UNITS="homelab-backup.service campaign-db-restore-test.service"
