# campaign-db backup/restore-test settings.
#
# Every value below is OPTIONAL — the defaults in the scripts already match
# the deployed stack, so the nightly dump works with no env file at all. Copy
# to campaign-db.env only to override.
#
#   cp campaign-db/env/campaign-db.env.example campaign-db/env/campaign-db.env
#
# No credentials live here: the scripts read POSTGRES_USER / POSTGRES_DB off
# the running container, so there is no second copy of a secret to drift.

# Container running the campaign Postgres.
#CS_PG_CONTAINER=campaign-settings-postgres

# Override only if the container's own env can't be read.
#CS_PG_USER=postgres
#CS_PG_DB=campaign_settings

# Where dumps land. MUST stay under /home/youruser/homelab — that is what puts
# them in restic's scope and therefore on the separate NVMe.
#CS_DUMP_DIR=/home/youruser/homelab/campaign-db/data

# Local dump retention. The long tail lives in restic (7d/4w/6m); these are a
# fast-restore cache. CS_DUMP_KEEP_MIN is a HARD FLOOR — pruning can never
# take the directory below it, whatever the age.
#CS_DUMP_KEEP_DAYS=14
#CS_DUMP_KEEP_MIN=3

# Tables the restore test asserts exist and are non-empty.
#CS_VERIFY_TABLES=worlds entities users
