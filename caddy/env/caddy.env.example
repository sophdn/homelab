# Bcrypt hash for the `claude` basicauth user gating /api/* (toolkit-server).
#
# Generate with:
#   docker run --rm caddy:2.8-alpine caddy hash-password --plaintext '<password>'
#
# IMPORTANT: Docker Compose v2 applies $VAR / ${VAR} substitution to values
# loaded via env_file. To pass a literal `$`, escape it as `$$`. A bcrypt hash
# `$2a$14$xyz...` therefore must be written here as `$$2a$$14$$xyz...`.
BASIC_AUTH_HASH_CLAUDE=$$2a$$14$$<placeholder>

# Tailnet hostname used by the portal-write-api site block. Reachable
# only from the tailnet — the Caddy stanza `bind`s to `tailscale0` so
# LAN clients can't resolve or reach it.
#
# Find your tailnet name in the Tailscale admin console; for a
# device named `mini-pc` on a tailnet `tail-abc123.ts.net`, the value
# is `mini-pc.tail-abc123.ts.net`.
TAILNET_PORTAL_HOST=mini-pc.<tailnet-name>.ts.net
